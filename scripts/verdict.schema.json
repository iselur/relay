{
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "criteria", "scope_finding", "regression_finding", "security_findings", "reasons", "spec_digest", "base_sha", "worker_commit", "schema_version", "quality"],
  "description": "Reviewer verdict v3 — mandatory structured rubric plus advisory quality dimensions (policy-note item 2). A PASS with empty reasons, or a PASS with any UNMET criterion, is rejected fail-closed by the dispatcher.",
  "properties": {
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "description": "One entry per spec acceptance_criterion, in order.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "result", "evidence"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "result": { "type": "string", "enum": ["MET", "UNMET"] },
          "evidence": { "type": "string", "minLength": 1, "description": "Concrete reference: path, line, or diff/test excerpt." }
        }
      }
    },
    "scope_finding": { "type": "string", "minLength": 1, "description": "Whether changed paths stayed within approved scope; cite any drift." },
    "regression_finding": { "type": "string", "minLength": 1, "description": "Any behaviour outside the criteria that the diff could break; 'none observed' is acceptable if justified." },
    "security_findings": { "type": "string", "minLength": 1, "description": "Injected secrets, unsafe shell, credential access, network use; 'none observed' if justified." },
    "reasons": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "spec_digest": { "type": "string" },
    "base_sha": { "type": "string" },
    "worker_commit": { "type": "string" },
    "schema_version": { "type": "string", "const": "3" },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maintainability", "design_fit", "test_quality"],
      "properties": {
        "maintainability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "evidence"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "evidence": { "type": "string", "pattern": "\\S" }
          }
        },
        "design_fit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "evidence"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "evidence": { "type": "string", "pattern": "\\S" }
          }
        },
        "test_quality": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "evidence"],
          "properties": {
            "score": { "type": "integer", "minimum": 1, "maximum": 5 },
            "evidence": { "type": "string", "pattern": "\\S" }
          }
        }
      }
    }
  }
}
