# Orchestrator runtime — tracked vs untracked (see CLAUDE.md).
# Approval artifacts ARE tracked (provenance). Per-attempt state, raw logs, event
# streams, mutable state, and worktrees are NOT (size/secrets).

# Per-attempt runtime state — audit record on the box, not repo content. History of the
# previously tracked copies stays reachable via git (each launch.json records its commit).
.orchestrator/attempts/

# Mutable runtime state (atomic writes; not provenance)
.orchestrator/state/

# Kill switch is a local signal, not repo content
.orchestrator/HALT

# Auto-resume watchdog runtime (locks, transcripts, offsets, session ids, alert incidents,
# mode-600 env with the alert credential — R39 brief: local-only, never tracked)
.orchestrator/watchdog/
.orchestrator/continue-session.sh
.orchestrator/continue.lock

# Per-attempt worktrees
.worktrees/

# Python venv (deps pinned in scripts/requirements.txt)
.venv/

# Python bytecode
__pycache__/
*.pyc

# Per-operator identity + local autonomy override (never shared; make copied approvals fail on clones)
.orchestrator/instance.json
.orchestrator/AUTONOMY.local.json

# Process prose is transient: plans and review rounds are untracked working files, deleted after
# the work ships. A decision that still binds gets one line in DECISIONS.md; arguments live in git
# history and PR descriptions. tests/prose_cap.sh enforces this. The same delete-on-ship policy
# applies to .orchestrator/evidence/ bundles (already untracked): delete once the work ships.
.orchestrator/plans/
.orchestrator/decisions/
.orchestrator/reviews/

# --- private: never publish (operator, 2026-07-13) ---
.orchestrator/REQUEST-LEDGER.md
.orchestrator/REQUEST-LEDGER.md.lock

# Claude-produced review artifacts for the operator (diagrams, drafts) — local only
claude-out/
